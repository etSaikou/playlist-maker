<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@color/wb_bg">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/vAddButton"
        style="@style/ErrorRefreshButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/playlist_create_new"
        android:layout_marginTop="@dimen/margin_24dp"/>
    <ImageView
        android:id="@+id/vPlaceholderImage"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_error_not_found_light_120"
        android:layout_marginTop="46dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="@dimen/margin_24dp"
        />
    <TextView
        android:id="@+id/vPlaceholderText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/margin16"
        android:textColor="@color/settings_text_button"
        android:fontFamily="@font/ys_display"
        android:textSize="19sp"
        android:text="@string/playlist_placeholder"
        android:textAlignment="center"
        />

</LinearLayout>